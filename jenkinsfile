pipeline {
    agent any 

    environment {
        CONTINAER_NAME = "task_manager_app"
        IMAGE_NAME = "image_app"
        PORT = 8000
        EMAIL="mdshaisakhter840@gmail.com"

    }

    stages{
        stage("Clonning reposiotry or checout"){
            steps{
                echo "Clonning project repository...."

               git branch: 'main',
               url: 'https://github.com/MdShais007/django-task-manager.git'

            }
        }

        stage("Building Image"){
            steps{
                sh " docker compose build "
            }
        }
      
        stage("Stop existing container"){
            steps{
                sh " docker compose down || true "
            }
        }

        stage("deploy container"){
            steps{
                sh " docker compose up -d "
            }
        }
        stage('Migrate') {
    steps {
        sh 'docker compose exec -T app python manage.py migrate'
    }

    }
}

 post {
        always {
            emailext(
                to: 'mdshaisakhter840@gmail.com',
                subject: "Status of Jenkins Build: ${currentBuild.fullDisplayName}",
                body: """The build completed with status: ${currentBuild.currentResult}.

Job: ${env.JOB_NAME}
Build Number: ${env.BUILD_NUMBER}
Build URL: ${env.BUILD_URL}
"""
            )
        }
    }

}